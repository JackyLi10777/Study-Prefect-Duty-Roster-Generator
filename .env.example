# ==========================================
# .env.example
# Sing Yin Study Prefect Duty Roster - v1.3
# 環境變數範例檔
# ==========================================

# ── Streamlit Cloud 相關（目前不需要填，但未來可擴充） ──
# STREAMLIT_SERVER_PORT=8501
# STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ── 未來可使用的外部 API 金鑰（目前 AI 解析為本地規則引擎，無需填寫） ──
# OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# GOOGLE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── 資料庫或備份相關（未來擴充用） ──
# DATABASE_URL=sqlite:///prefect.db
# BACKUP_GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── 校徽或自訂設定（可選） ──
# SCHOOL_LOGO_URL=https://your-domain.com/logo.png

# ==========================================
# 使用方法：
# 1. 把這個檔案複製成 .env
# 2. 把上面的 XXXXX 改成你自己的真實值
# 3. .env 會被 .gitignore 自動忽略，不會上傳 GitHub
# ==========================================
